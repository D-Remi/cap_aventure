# ============================================================
# CapAventure — Variables d'environnement
# Copier ce fichier en .env pour le dev local
# Sur Railway : ajouter ces variables dans "Variables" du service
# ============================================================

# ── Base de données ──────────────────────────────────────────
# En local (WAMP) :
DB_HOST=localhost
DB_PORT=3306
DB_USER=capaventure
DB_PASS=CHANGE_MOI
DB_NAME=capaventure

# Sur Railway : DATABASE_URL est fourni automatiquement par le plugin MySQL
# DATABASE_URL=mysql://user:pass@host:port/dbname

# ── Authentification ─────────────────────────────────────────
# Générer une clé forte : https://www.allkeysgenerator.com/Random/Security-Encryption-Key-Generator.aspx
JWT_SECRET=CHANGE_MOI_CLE_ALEATOIRE_TRES_LONGUE_AU_MOINS_64_CHARS

# ── Environnement ────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Email (Gmail) ─────────────────────────────────────────────
# Activer "Mots de passe d'application" sur ton compte Google
# https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=ton.email@gmail.com
MAIL_PASS=XXXX_XXXX_XXXX_XXXX
MAIL_FROM=CapAventure <ton.email@gmail.com>
ADMIN_EMAIL=ton.email@gmail.com

# ── URLs ─────────────────────────────────────────────────────
# URL du frontend déployé (sans / final)
# Ex: https://capaventure-frontend.up.railway.app
FRONTEND_URL=https://TON_FRONTEND.up.railway.app

# Origines autorisées pour CORS (séparées par virgule, sans espaces)
ALLOWED_ORIGINS=https://TON_FRONTEND.up.railway.app

# ── Uploads ──────────────────────────────────────────────────
# Sur Railway : monter un Volume et pointer ici
# UPLOADS_PATH=/data/uploads
