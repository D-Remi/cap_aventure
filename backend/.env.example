# ============================================================
# CapAventure — Variables d'environnement
# Sur le VPS : copier en /var/www/cap_aventure/backend/.env
# ============================================================

NODE_ENV=production
PORT=3001

# ── Base de données ──────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=capaventure
DB_PASS=CHANGER_MOI
DB_NAME=capaventure

# ── JWT ───────────────────────────────────────────────────────
# Générer : https://www.allkeysgenerator.com → 512-bit
JWT_SECRET=CHANGER_MOI_CLE_512BIT
JWT_EXPIRES=7d

# ── Email Gmail ───────────────────────────────────────────────
# https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=ton.email@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
MAIL_FROM=CapAventure <ton.email@gmail.com>
ADMIN_EMAIL=ton.email@gmail.com

# ── URLs ──────────────────────────────────────────────────────
FRONTEND_URL=https://capaventure74.fun
ALLOWED_ORIGINS=https://capaventure74.fun,https://www.capaventure74.fun
